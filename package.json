{
  "name": "3-shake-engineers-blogs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "run-s build:posts build:feed build:next",
    "build:posts": "ts-node --project tsconfig.builder.json ./src/builder/posts.ts",
    "build:feed": "NODE_ENV=production ts-node --project tsconfig.builder.json ./src/builder/feed.ts",
    "build:next": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "dayjs": "1.11.20",
    "next": "15.5.12",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "feed": "5.1.0",
    "fs-extra": "11.3.4",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "rss-parser": "3.13.0",
    "sass": "1.98.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "volta": {
    "node": "24.14.0",
    "yarn": "4.12.0"
  }
