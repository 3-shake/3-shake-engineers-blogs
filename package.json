{
  "name": "3-shake-engineers-blogs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "run-s build:posts build:favicons build:feed build:next",
    "build:posts": "tsx ./src/builder/posts.ts",
    "build:favicons": "tsx ./src/builder/favicons.ts",
    "build:avatars": "tsx ./src/builder/avatars.ts",
    "build:feed": "NODE_ENV=production tsx ./src/builder/feed.ts",
    "build:next": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "dayjs": "1.11.20",
    "next": "15.5.15",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "8.57.0",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "feed": "5.2.1",
    "fs-extra": "11.3.4",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "rss-parser": "3.13.0",
    "sass": "1.99.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
